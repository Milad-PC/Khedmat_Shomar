@model ErrorViewModel
@{
    ViewData["Title"] = "خطا";
}

<div class="card error-card">
    <h1>یه مشکلی پیش اومد!</h1>
    <p>در پردازش درخواست خطایی رخ داد. دوباره تلاش کن.</p>
    @if (Model.ShowRequestId)
    {
        <p><code>@Model.RequestId</code></p>
    }
    <a href="/" class="btn-primary" style="display:inline-block;width:auto;padding:12px 28px;text-decoration:none;margin-top:8px">بازگشت به خانه</a>
</div>
