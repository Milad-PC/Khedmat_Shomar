<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#141710" />
    <meta name="description" content="خدمت‌شمار — شمارش معکوس پایان خدمت سربازی" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")خدمت‌شمار</title>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="~/icons/icon.svg" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <!-- SEO -->
    <meta name="google-site-verification" content="T7yz-gvijNCqME7vGJeNF1oQekb7sA1Keq10rLibR6c" />
    <meta name="description" content="خدمت شمار رایگان با قابلیت نصب روی گوشی" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://khedmatshomar.ir/" />
    <meta property="og:title" content="خدمت شمار رایگان">
    <meta property="og:description" content="خدمت شمار رایگان با قابلیت نصب روی گوشی">
    <meta name="twitter:image" content="~/icon/icon-192.png">
    <meta property="og:image" content="~/icon/icon-512.png">
    <meta property="og:url" content="https://khedmatshomar.ir/">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="khedmatshomar">
    <meta property="og:locale" content="fa_IR" />
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@ViewData["Title"]">
    <meta name="twitter:description" content="خدمت شمار رایگان با قابلیت نصب روی گوشی">
    <meta name="copyright" content="Light Company">
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "WebApplication",
          "name": "خدمت شمار",
          "url": "https://khedmatshomar.ir/",
          "description": "خدمت شمار رایگان با قابلیت نصب روی گوشی",
          "applicationCategory": "LifestyleApplication",
          "operatingSystem": "Any",
          "offers": {
            "@@type": "Offer",
            "price": "0"
          }
        }
    </script>
    <!-- End SEO -->
    <script>
        // جلوگیری از فلش تم اشتباه قبل از رندر
        (function () {
            try {
                var t = localStorage.getItem('ks_theme');
                if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
            } catch (e) { }
        })();
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page">
        <header class="app-header">
            <div class="brand">
                <div class="brand-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent-ink)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 7.5 L12 12.5 L19 7.5"></path><path d="M5 13.5 L12 18.5 L19 13.5"></path></svg>
                </div>
                <div class="brand-text">
                    <div class="brand-title">خدمت‌شمار</div>
                    <div class="brand-sub">شمارش معکوس پایان خدمت</div>
                </div>
            </div>
            <button type="button" id="themeToggle" class="theme-toggle">
                <span class="theme-dot"></span>
                <span id="themeLabel">روشن</span>
            </button>
        </header>

        <main class="main-col">
            @RenderBody()
        </main>

        <div class="ad-wrap">
            <div class="ad-slot" id="adSlot" style="position:relative;overflow:hidden">
                 <img src="~/ads/ChatGPT Image Jul 4, 2026, 11_57_08 AM.png" style="position:absolute;max-width:100%" />
            </div>
        </div>

        <footer class="app-footer">
            <button type="button" id="openInstallModal" class="footer-link">راهنمای نصب اپلیکیشن</button>
            <span class="footer-credit">طراحی توسط <a class="footer-link" href="https://lightcompany.ir/">لایت کمپانی</a></span>
        </footer>
    </div>

    <div id="installModal" class="modal-overlay" hidden>
        <div class="modal-card" dir="rtl" role="dialog" aria-modal="true" aria-labelledby="installTitle">
            <div class="modal-head">
                <div class="modal-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-ink)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4 L12 15"></path><path d="M7 11 L12 16 L17 11"></path><path d="M5 20 L19 20"></path></svg>
                </div>
                <div id="installTitle" class="modal-title">خدمت‌شمار رو نصب کن!</div>
            </div>
            <div class="modal-desc">اپ رو به صفحه اصلی گوشیت اضافه کن تا هر روز بدون باز کردن مرورگر ببینی چقدر مونده.</div>

            <div class="modal-guides">
                <div class="guide-card">
                    <div class="guide-title">اندروید (کروم)</div>
                    <div class="guide-body">منوی ⋮ بالای مرورگر را بزن، بعد «افزودن به صفحه اصلی» (Add to Home screen) و در آخر «نصب» را تایید کن.</div>
                </div>
                <div class="guide-card">
                    <div class="guide-title">آیفون (سافاری)</div>
                    <div class="guide-body">دکمه Share (مربع با فلش رو به بالا) را بزن، بعد «Add to Home Screen» و در آخر «Add».</div>
                </div>
            </div>

            <button type="button" id="installAction" class="btn-primary modal-btn" hidden>نصب اپلیکیشن</button>
            <button type="button" id="closeInstallModal" class="btn-primary modal-btn">متوجه شدم</button>
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
